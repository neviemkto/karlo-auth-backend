# ── COPY THIS FILE TO .env AND FILL IN YOUR VALUES ───────────────────────────
# DO NOT commit .env to GitHub — add it to .gitignore!

# MongoDB Atlas connection string (get from atlas.mongodb.com → Connect → Drivers)
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/karlos-auth?retryWrites=true&w=majority

# Secret key for signing JWT tokens — make this long and random!
# You can generate one with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_LONG_RANDOM_STRING_64_CHARS_MINIMUM

# Gmail address you want to send password reset emails from
EMAIL_USER=yourgmail@gmail.com

# Gmail APP PASSWORD (NOT your real password!)
# Google Account → Security → 2-Step Verification → App passwords
EMAIL_PASS=xxxx xxxx xxxx xxxx

# Comma-separated list of allowed origins for CORS
# Add all domains your games are hosted on
ALLOWED_ORIGINS=https://k4rl0.itch.io,https://yoursite.com,http://localhost:5500

# Fallback game URL for password reset links (used if frontend doesn't send one)
GAME_URL=https://yoursite.com
